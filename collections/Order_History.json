{
  "name": "Order_History",
  "titleField": "order_id",
  "fields": {
    "order_id": {
      "type": "primary_key"
    },
    "product_id": {
      "type": "foreign_key",
      "relation": {
        "collection": "Products",
        "field": "product_id"
      }
    },
    "order_date": {
      "type": "date"
    },
    "order_quantity": {
      "type": "number"
    },
    "total_cost": {
      "type": "number"
    },
    "status": {
      "type": "singleSelect",
      "options": {
        "choices": [
          {
            "name": "Pending"
          },
          {
            "name": "Delivered"
          },
          {
            "name": "Cancelled"
          }
        ]
      }
    }
  }
}
