{
  "name": "inventory",
  "displayName": "Inventory",
  "description": "Inventory workspace with Suppliers, Products, Inventory, Shipments, and Order_History.",
  "version": "0.2.1",
  "mochi-cli": ">=0.1.0",
  "collections": [
    {
      "name": "Suppliers",
      "schema": {
        "titleField": "supplier_name",
        "fields": {
          "supplier_id": {
            "type": "primary_key"
          },
          "supplier_name": {
            "type": "string"
          },
          "supplier_contact": {
            "type": "string"
          },
          "supplier_address": {
            "type": "text"
          }
        }
      }
    },
    {
      "name": "Products",
      "schema": {
        "titleField": "product_name",
        "fields": {
          "product_id": {
            "type": "primary_key"
          },
          "product_name": {
            "type": "string"
          },
          "unit_price": {
            "type": "number"
          },
          "quantity_in_stock": {
            "type": "number"
          }
        }
      }
    },
    {
      "name": "Inventory",
      "schema": {
        "titleField": "inventory_id",
        "fields": {
          "inventory_id": {
            "type": "primary_key"
          },
          "product_id": {
            "type": "foreign_key",
            "relation": {
              "collection": "Products",
              "field": "product_id"
            }
          },
          "quantity_available": {
            "type": "number"
          },
          "last_stock_update": {
            "type": "timestamp"
          }
        }
      }
    },
    {
      "name": "Shipments",
      "schema": {
        "titleField": "shipment_id",
        "fields": {
          "shipment_id": {
            "type": "primary_key"
          },
          "product_id": {
            "type": "foreign_key",
            "relation": {
              "collection": "Products",
              "field": "product_id"
            }
          },
          "supplier_id": {
            "type": "foreign_key",
            "relation": {
              "collection": "Suppliers",
              "field": "supplier_id"
            }
          },
          "quantity_shipped": {
            "type": "number"
          },
          "shipment_date": {
            "type": "date"
          }
        }
      }
    },
    {
      "name": "Order_History",
      "schema": {
        "titleField": "order_id",
        "fields": {
          "order_id": {
            "type": "primary_key"
          },
          "product_id": {
            "type": "foreign_key",
            "relation": {
              "collection": "Products",
              "field": "product_id"
            }
          },
          "order_date": {
            "type": "date"
          },
          "order_quantity": {
            "type": "number"
          },
          "total_cost": {
            "type": "number"
          },
          "status": {
            "type": "singleSelect",
            "options": {
              "choices": [
                {
                  "name": "Pending"
                },
                {
                  "name": "Delivered"
                },
                {
                  "name": "Cancelled"
                }
              ]
            }
          }
        }
      }
    }
  ],
  "relationships": [
    "Suppliers and Shipments: One-to-Many",
    "Products and Inventory: One-to-One",
    "Products and Shipments: One-to-Many",
    "Products and Order_History: One-to-Many"
  ]
}
