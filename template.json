{
  "name": "inventory",
  "displayName": "Inventory",
  "description": "Inventory workspace with Suppliers, Products, Inventory, Shipments, and Order_History.",
  "version": "0.2.0",
  "mochikit": ">=0.1.0",
  "collections": [
    {
      "name": "Suppliers",
      "schema": {
        "titleField": "supplier_name",
        "fields": {
          "supplier_id": "primary_key",
          "supplier_name": "string",
          "supplier_contact": "string",
          "supplier_address": "text"
        }
      }
    },
    {
      "name": "Products",
      "schema": {
        "titleField": "product_name",
        "fields": {
          "product_id": "primary_key",
          "product_name": "string",
          "unit_price": "number",
          "quantity_in_stock": "number"
        }
      }
    },
    {
      "name": "Inventory",
      "schema": {
        "titleField": "inventory_id",
        "fields": {
          "inventory_id": "primary_key",
          "product_id": "foreign_key:Products(product_id)",
          "quantity_available": "number",
          "last_stock_update": "timestamp"
        }
      }
    },
    {
      "name": "Shipments",
      "schema": {
        "titleField": "shipment_id",
        "fields": {
          "shipment_id": "primary_key",
          "product_id": "foreign_key:Products(product_id)",
          "supplier_id": "foreign_key:Suppliers(supplier_id)",
          "quantity_shipped": "number",
          "shipment_date": "date"
        }
      }
    },
    {
      "name": "Order_History",
      "schema": {
        "titleField": "order_id",
        "fields": {
          "order_id": "primary_key",
          "product_id": "foreign_key:Products(product_id)",
          "order_date": "date",
          "order_quantity": "number",
          "total_cost": "number",
          "status": "Pending|Delivered|Cancelled"
        }
      }
    }
  ],
  "relationships": [
    "Suppliers and Shipments: One-to-Many",
    "Products and Inventory: One-to-One",
    "Products and Shipments: One-to-Many",
    "Products and Order_History: One-to-Many"
  ]
}
